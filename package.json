{
  "name": "cursor-proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter @cursor-proxy/server dev",
    "runner:dev": "bun --filter @cursor-proxy/runner dev",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json --pretty false",
    "lint": "biome check .",
    "format": "biome check --write .",
    "build": "bun --filter '*' build",
    "node:build": "pnpm --filter @cursor-proxy/server build:node",
    "node:start": "pnpm --filter @cursor-proxy/server start:node",
    "live:composer-toolcall": "bun run scripts/live-composer-toolcall-qa.ts",
    "check:no-excuse": "node scripts/check-no-excuse-rules.mjs",
    "check": "bun run typecheck && bun run lint && bun run check:no-excuse && bun test && bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.19.1",
    "typescript": "^6.0.3",
    "vitest": "^4.0.14"
  }
}
